{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "bash scripts/vercel_install.sh",
  "functions": {
    "api/webhook.py": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/cron.py": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "* * * * *"
    }
  ],
  "env": {
    "PYTHONPATH": ".:lib"
  }
}
